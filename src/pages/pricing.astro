---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '价格',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="价格"
    title="为每个旅程提供卓越的价格"
    subtitle="选择与您的目标相符的完美计划。"
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="我们的价格"
    subtitle="只为您需要的付费"
    prices={[
      {
        title: '基础',
        subtitle: '个人使用的最佳选择',
        price: 29,
        period: '每月',
        items: [
          {
            description: '基础模板访问',
          },
          {
            description: '基本支持',
          },
          {
            description: '有限的定制选项',
          },
          {
            description: '个人使用许可',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '开始使用',
          href: '#',
        },
      },
      {
        title: '标准',
        subtitle: '小型团队的最佳选择',
        price: 69,
        period: '每月',
        items: [
          {
            description: '所有基础功能',
          },
          {
            description: '优先支持',
          },
          {
            description: '更多定制选项',
          },
          {
            description: '团队使用许可',
          },
          {
            description: '高级模板访问',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '开始使用',
          href: '#',
        },
        hasRibbon: true,
        ribbonTitle: '热门',
      },
      {
        title: '高级',
        subtitle: '公司的最佳选择',
        price: 199,
        period: '每月',
        items: [
          {
            description: '所有标准功能',
          },
          {
            description: '24/7 支持',
          },
          {
            description: '完全定制选项',
          },
          {
            description: '商业使用许可',
          },
        ],
        callToAction: {
          target: '_blank',
          text: '开始使用',
          href: '#',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="价格相关特性"
    subtitle="发现选择我们计划的优势"
    columns={2}
    items={[
      {
        title: '分层价格计划',
        description: '从一系列价格计划中选择，这些计划专为适应不同预算和需求而设计。',
        icon: 'tabler:stairs',
      },
      {
        title: '透明定价',
        description: '每个计划的价格详情清晰显示，没有隐藏成本或意外费用。',
        icon: 'tabler:flip-vertical',
      },
      {
        title: '安全支付方式',
        description: '安全的支付网关，在交易过程中保护您的财务信息。',
        icon: 'tabler:shield-lock',
      },
      {
        title: '即时访问',
        description: `订阅后立即访问您所选计划的功能和模板。`,
        icon: 'tabler:accessible',
      },
      {
        title: '升级价值',
        description: '升级到更高层级的计划，解锁更多功能和福利，获得增强的体验。',
        icon: 'tabler:chevrons-up',
      },
      {
        title: '24小时支持',
        description: '通过实时聊天、电子邮件或电话回答问题，每个日历日都提供服务。',
        icon: 'tabler:headset',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="从计划到创意的引导之旅"
    tagline="简化流程"
    isReversed={true}
    items={[
      {
        title: '浏览计划',
        icon: 'tabler:number-1',
      },
      {
        title: '选择计划',
        icon: 'tabler:number-2',
      },
      {
        title: '注册/登录',
        icon: 'tabler:number-3',
      },
      {
        title: '查看订单',
        icon: 'tabler:number-4',
      },
      {
        title: '输入支付详情',
        icon: 'tabler:number-5',
      },
      {
        title: '确认',
        icon: 'tabler:number-6',
      },
      {
        title: '下载并开始使用模板',
        icon: 'tabler:number-7',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1536816579748-4ecb3f03d72a?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="价格常见问题"
    subtitle="选择正确的计划很重要，我们在这里为您解答问题。如果您对我们的价格选项有疑问，您来对地方了。"
    columns={1}
    items={[
      {
        title: '计划是否包含客户支持？',
        description:
          '当然，所有计划都包含访问我们专门的客户支持，以帮助您解决任何查询或疑虑。',
      },
      {
        title: '不同计划有试用期吗？',
        description:
          "不幸的是，我们不为计划提供试用期。但是，您可以查看我们的演示部分来预览我们模板的质量。",
      },
      {
        title: '我可以在计划之间切换吗？',
        description:
          '当然！您可以随时轻松升级或降级您的计划，以找到最适合您不断变化需求的计划。',
      },
      {
        title: '你们接受哪些支付方式？',
        description:
          '我们接受主要信用卡和在线支付方式，以确保便捷安全的交易过程。',
      },
      {
        title: '除了显示的成本外，还有任何隐藏费用吗？',
        description:
          '不，订阅费用涵盖每个计划下列出的所有功能和模板。没有隐藏费用或额外收费。',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="准备好提升您的项目了吗？"
    subtitle="加入我们的满意客户社区，他们已经通过我们的模板转变了他们的工作。"
    actions={[
      {
        variant: 'primary',
        text: '立即开始',
        href: '/',
      },
    ]}
  />
</Layout>
