---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '微光助行',
  ignoreTitleTemplate: true,
};c
---

<Layout metadata={metadata}>
  <Fragment slot="announcement" />
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: '获取模板',
        href: 'https://github.com/onwidget/astrowind',
        target: '_blank',
        icon: 'tabler:download',
      },
      { text: '了解更多', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'AstroWind Hero Image' }}
  >
    <Fragment slot="title">
      免费模板 <span class="hidden xl:inline">用于创建</span>
      <span class="text-accent dark:text-white highlight"> Astro 4.0</span> + Tailwind CSS 网站
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">AstroWind</span> 是一个免费、可定制且适合生产环境的 Astro 4.0
        + Tailwind CSS 模板。</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">AstroWind: 生产就绪。</span>
      适用于初创企业、小型企业、SaaS 网站、专业作品集、营销网站、落地页和博客。
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="特性"
    title="AstroWind 能为你带来什么"
    subtitle="目前市场上最专业、最全面的模板之一。2022 年最受关注和分叉的 Astro 主题。"
    items={[
      {
        title: 'Astro + Tailwind CSS 集成',
        description:
          '两大优秀框架的无缝集成，提供高生产力、性能和多功能性。',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: '即用型组件',
        description:
          '使用 Tailwind CSS 制作的小部件，可直接用于营销网站、SaaS、博客、个人简介、小型企业...',
        icon: 'tabler:components',
      },
      {
        title: '最佳实践',
        description:
          '创建安全、高效且用户友好的网站，提供卓越的体验和持久的价值。',
        icon: 'tabler:list-check',
      },
      {
        title: '出色的页面速度',
        description:
          '良好的页面速度会影响自然搜索排名，改善用户体验 (UI/UX) 并提高转化率。',
        icon: 'tabler:rocket',
      },
      {
        title: '搜索引擎优化 (SEO)',
        description:
          "SEO 的核心在于提升网站可见性，带来自然流量并触达更广泛的受众。",
        icon: 'tabler:arrows-right-left',
      },
      {
        title: '开放新想法和贡献',
        description:
          '拥抱开放的文化，接受新想法和贡献，促进创新、协作和动态的用户体验。',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="模板内部"
    title="AstroWind 的蓝图：趣味与功能的完美结合！"
    items={[
      {
        title: '基于 Astro 4.0 构建',
        description:
          '受益于这款现代静态站点生成器的性能和开发者友好特性。',
      },
      {
        title: '使用 Tailwind CSS 样式',
        description:
          '借助这款广受欢迎的实用优先 CSS 框架，实现快速设计和一致的样式。',
      },
      {
        title: '跨浏览器兼容性',
        description:
          '确保您的网站在各种浏览器中外观和功能一致，为所有用户提供无缝体验。',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">构建于现代基础之上</h3>
      通过采用行业领先实践获得竞争优势
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: '高度可定制',
        description: `轻松定制模板以匹配您的品牌形象和需求，让您的网站独具特色，节省您的时间。`,
      },
      {
        title: '多种布局可能',
        description:
          '探索各种布局选项，找到最能展示您内容的结构，增强用户参与度和导航体验。',
      },
      {
        title: '完全响应式设计',
        description:
          "确保您的网站在各种设备和屏幕尺寸上都能获得最佳性能，提供一致且愉快的用户体验。",
      },
      {
        title: '媒体集成',
        description:
          '无缝整合图片、视频和多媒体元素，增强您的内容并有效吸引访客。',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Blueprint Image',
    }}
  >
    <Fragment slot="content">确保您的在线形象真正代表您。</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: '增强的用户参与度',
        description:
          '通过交互式元素、直观的导航和视觉上吸引人的布局来吸引您的受众，鼓励更长时间的访问。',
      },
      {
        title: '持续改进',
        description:
          '通过定期更新和增强，确保您的网站与最新趋势和技术保持同步。',
      },
      {
        title: '时间和资源效率',
        description:
          '跳过从头开始构建网站的耗时过程，使用 AstroWind 更快地启动您的在线形象。',
      },
      {
        title: '社区支持',
        description: `加入不断发展的 AstroWind 社区，获取见解、资源和帮助，确保您在 Web 开发之旅中永不孤单。`,
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611462985358-60d3498e0364?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Astronauts Image',
    }}
  >
    <Fragment slot="content">旨在促进成长和成功。</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="使用 AstroWind 快速启动您梦想中的网站。"
    items={[
      {
        title: '步骤 1: <span class="font-medium">下载</span>',
        description:
          "从 GitHub 开始！分叉 AstroWind 模板或简单点击'使用此模板'。您的画布已准备好，等待您的数字杰作。只需几次点击，您就已经奠定了基础。",
        icon: 'tabler:package',
      },
      {
        title: '步骤 2: <span class="font-medium">添加内容</span>',
        description:
          "将您的愿景注入其中。添加图片、文本和各种元素，为您的数字空间注入活力。记住，是内容讲述您的故事，所以要让它引人入胜。",
        icon: 'tabler:letter-case',
      },
      {
        title: '步骤 3: <span class="font-medium">自定义样式</span>',
        description:
          '赋予它您的个人风格。调整颜色、字体和布局，直到感觉恰到好处。您独特的风格，由 AstroWind 放大！精确的设计确保无缝的用户体验。',
        icon: 'tabler:paint',
      },
      {
        title: '完成！',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="我们的团队"
    subtitle="通过以下信息，您将更了解我们团队"
    tagline="关于我们"
    items={[
      {
        title: '周**（组长）',
        description: "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:template',
      },
      {
        title: '何*（副组长）',
        description:
          "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:gallery',
      },
      {
        title: '王**（副组长）',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:approval',
      },
      {
        title: '邓**',
        description:
          "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:document',
      },
      {
        title: '冯**',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: '胡刘*',
        description: '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:currency-exchange',
      },
      {
        title: '胡迎*',
        description: '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '钱**',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: '杨**',
        description: "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:database',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="在我们的博客中发现更多内容"
    information={`博客用于展示我们的活动。
                        每篇新文章都是一项我们所进行的活动。
                `}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="常见问题"
    subtitle="深入了解以下问题，了解为什么建议您选择我们以及帮助您解决在过程中所遇到的问题。"
    tagline="常见问题"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '为什么选择我们？',
        description:
          "AstroWind 结合了 Astro 的高性能和 Tailwind CSS 的灵活性，为您提供了一个快速、现代且易于定制的网站模板。无论您是构建个人博客还是企业网站，AstroWind 都能满足您的需求。",
      },
      {
        title: '开始需要什么？',
        description:
          '您只需要基本的 HTML、CSS 和 JavaScript 知识，以及对 Astro 框架的基本了解。我们的文档将指导您完成整个过程，从安装到部署。',
      },
      {
        title: '如何安装 Astro + Tailwind CSS 模板？',
        description:
          "安装非常简单！只需从 GitHub 分叉或下载模板，运行 npm install 安装依赖，然后使用 npm run dev 启动开发服务器。详细步骤请参阅我们的文档。",
      },
      {
        title: "我可以自定义模板吗？",
        description:
          "当然可以！AstroWind 的设计初衷就是易于定制。您可以轻松修改颜色、字体、布局和内容，以匹配您的品牌形象。",
      },
      {
        title: 'AstroWind 支持哪些功能？',
        description:
          "AstroWind 包含响应式设计、SEO 优化、暗色模式、博客功能、联系表单等现代网站所需的一切功能。",
      },
      {
        title: '遇到了其他问题？',
        description:
          "您可以查看我们的文档、加入社区讨论，或在 GitHub 上提交问题。我们活跃的开发社区随时准备为您提供帮助。",
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: '下载量', amount: '132K' },
      { title: '星标', amount: '24.8K' },
      { title: '分叉', amount: '10.3K' },
      { title: '用户', amount: '48.4K' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '获取模板',
        href: 'https://github.com/onwidget/astrowind',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      Astro&nbsp;+&nbsp;<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Tailwind CSS</span>
    </Fragment>

    <Fragment slot="subtitle">
      不要被这个页面上看到的这些巨大的虚假数字吓到。 <br class="hidden md:inline" />别再浪费时间了！:P
    </Fragment>
  </CallToAction>
</Layout>
