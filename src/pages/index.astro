---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '微光助行',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement" />
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: '获取模板',
        href: 'https://github.com/onwidget/astrowind',
        target: '_blank',
        icon: 'tabler:download',
      },
      { text: '了解更多', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'AstroWind Hero Image' }}
  >
    <Fragment slot="title">
      微 <span class="hidden xl:inline">光</span>
      <span class="text-accent dark:text-white highlight"> Astro 4.0</span> + Tailwind CSS 网站
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">一个</span> 方便广大旧物循环的网站</span
      >
      <span class="block mb-1 sm:hidden font-bold text-blue-600">本网站: 生产就绪。</span>
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="特性"
    title="我们 能为你带来什么"
    subtitle="专业，全面，系统性的服务"
    items={[
      {
        title: '快速响应',
        description:
          '地处长沙市岳麓区，服务响应快',
        icon: 'tabler:brand-tailwind',
      },
      {
        title: '广阔的服务范围',
        description:
          '覆盖多种资源的循环与回收利用',
        icon: 'tabler:components',
      },
      {
        title: '最佳实践',
        description:
          '创建安全、高效且用户友好的网站，提供卓越的体验和持久的价值。',
        icon: 'tabler:list-check',
      },
      {
        title: '出色的页面速度',
        description:
          '良好的页面速度会影响自然搜索排名，改善用户体验 (UI/UX) 并提高转化率。',
        icon: 'tabler:rocket',
      },
      {
        title: '功能优化进行',
        description:
          "我们不断改进我们的网站，以提供更好的服务",
        icon: 'tabler:arrows-right-left',
      },
      {
        title: '开放新想法和贡献',
        description:
          '拥抱开放的文化，接受新想法和贡献，促进创新、协作和用户体验。',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="模板内部"
    title="AstroWind 的蓝图：趣味与功能的完美结合！"
    items={[
      {
        title: '基于 Astro 4.0 构建',
        description:
          '受益于这款现代静态站点生成器的性能和开发者友好特性。',
      },
      {
        title: '使用 Tailwind CSS 样式',
        description:
          '借助这款广受欢迎的实用优先 CSS 框架，实现快速设计和一致的样式。',
      },
      {
        title: '跨浏览器兼容性',
        description:
          '确保您的网站在各种浏览器中外观和功能一致，为所有用户提供无缝体验。',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Colorful Image',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">构建于现代基础之上</h3>
      通过采用行业领先实践获得竞争优势
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: '高度可定制',
        description: `轻松定制模板以匹配您的品牌形象和需求，让您的网站独具特色，节省您的时间。`,
      },
      {
        title: '多种布局可能',
        description:
          '探索各种布局选项，找到最能展示您内容的结构，增强用户参与度和导航体验。',
      },
      {
        title: '完全响应式设计',
        description:
          "确保您的网站在各种设备和屏幕尺寸上都能获得最佳性能，提供一致且愉快的用户体验。",
      },
      {
        title: '媒体集成',
        description:
          '无缝整合图片、视频和多媒体元素，增强您的内容并有效吸引访客。',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Blueprint Image',
    }}
  >
    <Fragment slot="content">确保您的在线形象真正代表您。</Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

 

  <!-- Steps Widget ****************** -->

  <Steps
    title="使用 AstroWind 快速启动您梦想中的网站。"
    items={[
      {
        title: '步骤 1: <span class="font-medium">访问</span>',
        description:
          "访问本网站，右上角点击“联系我们“ ",
        icon: 'tabler:package',
      },
      {
        title: '步骤 2: <span class="font-medium">描述内容</span>',
        description:
          "具体描述您的要求，并提交",
        icon: 'tabler:letter-case',
      },
      

      {
        title: '完成！',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1616198814651-e71f960c3180?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="我们的团队"
    subtitle="通过以下信息，您将更了解我们团队"
    tagline="关于我们"
    items={[
      {
        title: '周**（组长）',
        description: "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '何*（副组长）',
        description:
          "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '王**（副组长）',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '邓**',
        description:
          "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '冯**',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '胡刘*',
        description: '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '胡迎*',
        description: '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: '钱**',
        description:
          '湖南师范大学物理与电子科学学院',
        icon: 'flat-color-icons:voice-presentation', //
      },
      {
        title: '杨**',
        description: "湖南师范大学物理与电子科学学院",
        icon: 'flat-color-icons:voice-presentation',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts
    title="在我们的博客中发现更多内容"
    information={`博客用于展示我们的活动。
                        每篇新文章都是一项我们所进行的活动。
                `}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="常见问题"
    subtitle="深入了解以下问题，了解为什么建议您选择我们以及帮助您解决在过程中所遇到的问题。"
    tagline="常见问题"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '为什么选择我们？',
        description:
          "AstroWind 结合了 Astro 的高性能和 Tailwind CSS 的灵活性，为您提供了一个快速、现代且易于定制的网站模板。无论您是构建个人博客还是企业网站，AstroWind 都能满足您的需求。",
      },
      {
        title: '开始需要什么？',
        description:
          '您只需要基本的 HTML、CSS 和 JavaScript 知识，以及对 Astro 框架的基本了解。我们的文档将指导您完成整个过程，从安装到部署。',
      },
      {
        title: '如何安装 Astro + Tailwind CSS 模板？',
        description:
          "安装非常简单！只需从 GitHub 分叉或下载模板，运行 npm install 安装依赖，然后使用 npm run dev 启动开发服务器。详细步骤请参阅我们的文档。",
      },
      {
        title: "我可以自定义模板吗？",
        description:
          "当然可以！AstroWind 的设计初衷就是易于定制。您可以轻松修改颜色、字体、布局和内容，以匹配您的品牌形象。",
      },
      {
        title: 'AstroWind 支持哪些功能？',
        description:
          "AstroWind 包含响应式设计、SEO 优化、暗色模式、博客功能、联系表单等现代网站所需的一切功能。",
      },
      {
        title: '遇到了其他问题？',
        description:
          "您可以查看我们的文档、加入社区讨论，或在 GitHub 上提交问题。我们活跃的开发社区随时准备为您提供帮助。",
      },
    ]}
  />

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: '下载量', amount: '132K' },
      { title: '星标', amount: '24.8K' },
      { title: '分叉', amount: '10.3K' },
      { title: '用户', amount: '48.4K' },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '联系我们',
        href: '/contact',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">
      微光<br class="block sm:hidden" /><span class="sm:whitespace-nowrap">助行</span>
    </Fragment>

    <Fragment slot="subtitle">
      还在等什么？ <br class="hidden md:inline" />别再浪费时间了！
    </Fragment>
  </CallToAction>
</Layout>
