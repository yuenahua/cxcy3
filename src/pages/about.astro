---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '关于我们',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement" />
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="关于我们"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Caos Image',
    }}
  >
    <Fragment slot="title">
      用我们的 <br />
      <span class="text-accent dark:text-white highlight"> 精美网站模板</span> 提升您的在线形象
    </Fragment>

    <Fragment slot="subtitle">
      我们致力于为您提供高质量的网站模板，帮助您快速构建专业、美观的网站。无论是个人博客、企业网站还是电子商务平台，我们都能满足您的需求。
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="关于我们的统计"
    stats={[
      { title: '办公室', amount: '4' },
      { title: '员工', amount: '248' },
      { title: '模板', amount: '12' },
      { title: '奖项', amount: '24' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="我们的模板"
    subtitle="我们提供多种类型的网站模板，满足不同行业和需求的用户。所有模板都经过精心设计，确保美观、实用和易于定制。"
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: '教育',
        description:
          '为教育机构和教育工作者设计的专业模板，突出教育内容和课程信息。',
        icon: 'tabler:template',
      },
      {
        title: '室内设计',
        description:
          '为室内设计师和设计公司打造的展示模板，完美展示设计作品和服务。',
        icon: 'tabler:template',
      },
      {
        title: '摄影',
        description:
          '为摄影师和摄影工作室设计的作品集模板，突出摄影作品的视觉效果。',
        icon: 'tabler:template',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: '电子商务',
        description:
          '为在线商店和电商平台设计的专业模板，优化购物体验和转化率。',
        icon: 'tabler:template',
      },
      {
        title: '博客',
        description:
          '为博主和内容创作者设计的博客模板，提供良好的阅读体验和内容展示。',
        icon: 'tabler:template',
      },
      {
        title: '企业',
        description:
          '为企业和公司设计的专业网站模板，展示公司信息和服务。',
        icon: 'tabler:template',
      },
      {
        title: '品牌',
        description:
          '为品牌推广和市场营销设计的模板，突出品牌形象和核心价值。',
        icon: 'tabler:template',
      },
      {
        title: '医疗',
        description:
          '为医疗机构和医疗专业人士设计的专业模板，提供清晰的医疗信息和服务。',
        icon: 'tabler:template',
      },
      {
        title: '时尚设计',
        description:
          '为时尚设计师和时尚品牌设计的模板，展现时尚产品和品牌风格。',
        icon: 'tabler:template',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Colorful Image',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="我们的价值观"
    subtitle="我们坚持以下核心价值观，指导我们的工作和服务。"
    items={[
      {
        title: '以客户为中心',
        description:
          '我们始终将客户需求放在首位，努力提供最适合客户的解决方案和服务。',
      },
      {
        title: '持续改进',
        description:
          '我们不断学习和创新，提升产品质量和服务水平，适应不断变化的市场需求。',
      },
      {
        title: '诚信经营',
        description:
          '我们坚持诚实、透明的商业实践，建立与客户和合作伙伴的信任关系。',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="我们的成就"
    subtitle="我们在网站模板设计领域取得了显著成就，赢得了客户的信任和行业的认可。"
    isReversed={true}
    callToAction={{
      text: '了解更多',
      href: '/',
    }}
    items={[
      {
        title: '全球影响力',
        description: '我们的模板被全球各地的用户使用，帮助他们建立专业的在线形象。',
        icon: 'tabler:globe',
      },
      {
        title: '积极的客户反馈',
        description:
          '我们收到了来自客户的积极反馈和好评，这是对我们工作的最大肯定。',
        icon: 'tabler:message-star',
      },
      {
        title: '行业认可和奖项',
        description:
          '我们的设计和服务获得了行业专家的认可和多项奖项。',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="我们的位置"
    tagline="找到我们"
    columns={4}
    items={[
      {
        title: '美国',
        description: '1234 Lorem Ipsum St, 12345, Miami',
      },
      {
        title: '西班牙',
        description: '5678 Lorem Ipsum St, 56789, Madrid',
      },
      {
        title: '澳大利亚',
        description: '9012 Lorem Ipsum St, 90123, Sydney',
      },
      {
        title: '巴西',
        description: '3456 Lorem Ipsum St, 34567, São Paulo',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="技术支持"
    tagline="联系我们"
    columns={2}
    items={[
      {
        title: '在线聊天',
        description:
          '通过在线聊天与我们的客服团队实时沟通，获取即时帮助。',
        icon: 'tabler:messages',
      },
      {
        title: '电话联系',
        description:
          '通过电话与我们联系，我们的技术支持团队将为您提供专业的帮助。',
        icon: 'tabler:headset',
      },
    ]}
  />
</Layout>
