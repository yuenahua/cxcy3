---
import Layout from '~/layouts/LandingLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '预发布登录页面',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="预发布演示"
    title="预发布登录页面：在大揭秘前营造 hype！"
    subtitle="制作一个诱人的即将推出或预发布登录页面，让访问者急切地等待您的发布。"
    actions={[
      { variant: 'primary', text: '行动号召', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: '了解更多', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558803116-c1b4ac867b31?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2069&q=80',
      alt: 'Store with a Coming Soon sign. Pre-launch Landing Page',
    }}
  />

  <CallToAction
    title="即将推出"
    subtitle="我们正在处理这些演示页面的内容。您很快就会看到它们。敬请期待！"
    actions={[
      {
        variant: 'primary',
        text: '下载模板',
        href: 'https://github.com/onwidget/astrowind',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
