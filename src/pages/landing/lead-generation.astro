---
import Layout from '~/layouts/LandingLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: '潜在客户生成登录页面演示',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero
    tagline="潜在客户生成登录演示"
    title="有效的潜在客户生成登录页面：解锁秘密"
    subtitle="发现创建将好奇的访问者转变为渴望的潜在客户的登录页面的秘密。（您的Hero应该立即吸引注意力。使用直接针对目标受众的有力标题。）"
    actions={[
      { variant: 'primary', text: '行动号召', href: '#', icon: 'tabler:square-rounded-arrow-right' },
      { text: '了解更多', href: '#' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1597423498219-04418210827d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1674&q=80',
      alt: 'Magnet attracting screws. Lead generation landing page demo',
    }}
  />

  <CallToAction
    title="即将推出"
    subtitle="我们正在处理这些演示页面的内容。您很快就会看到它们。敬请期待！"
    actions={[
      {
        variant: 'primary',
        text: '下载模板',
        href: 'https://github.com/onwidget/astrowind',
        icon: 'tabler:download',
      },
    ]}
  />
</Layout>
